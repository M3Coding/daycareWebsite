  <script>
    function init3DCarousel(wrapper) {
      const track = wrapper.querySelector('.carousel-3d-track');
      const slides = wrapper.querySelectorAll('.carousel-3d-slide');
      let currentIndex = 0;
      const total = slides.length;
      const angle = 360 / total;

      slides.forEach((slide, i) => {
        slide.style.transform = `rotateY(${i * angle}deg) translateZ(350px)`;
      });

      function rotateTo(index) {
        track.style.transform = `rotateY(${-index * angle}deg)`;
      }

      function rotate(dir) {
        currentIndex += dir;
        rotateTo(currentIndex);
      }

      wrapper.querySelector('.carousel-3d-btn.prev').addEventListener('click', () => rotate(-1));
      wrapper.querySelector('.carousel-3d-btn.next').addEventListener('click', () => rotate(1));

      rotateTo(0);
      setInterval(() => rotate(1), 4000);
    }

    document.querySelectorAll('.carousel-3d-wrapper').forEach(wrapper => init3DCarousel(wrapper));
  </script>

