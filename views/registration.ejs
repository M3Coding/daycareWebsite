
<link rel="stylesheet" href="/styles/styles.css" />
<link rel="stylesheet" href="/styles/registration.css" />
<div class="registrationPage" id="registrationPage" name="registrationPage">
    <div class="logo-container">
        <img class="logo" src="/images/daycareLogo.png" alt="daycare logo" />
    </div>
    <div class="registrationContainer" id="registrationContainer" name="registrationContainer">
        <div class="registrationContent" id="registrationContent" name="registrationContent">
            <form action="/registration" target="_blank" method="post" id="registration-form">
                <input type="text" id="fname" name="fname" placeholder="First Name" required><br>
                
                <input type="text" id="lname" name="lname" placeholder="Last Name" required><br>
                
                <input type="text" id="email" name="email" placeholder="Email" required><br>
                
                <input type="password" id="password" name="password" placeholder="Password" required><br>
                <input type="submit">
            </form>
            

        </div>
        <div class="registrationinfo" id="registrationinfo" name="registrationinfo" >
            
            <p><i>This information will be securely stored!</i></p>

        </div>

    </div>

</div>
